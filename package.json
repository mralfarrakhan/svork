{
  "name": "svork",
  "type": "module",
  "version": "0.0.0",
  "description": "Svelte utilities for writing blog",
  "author": "mralfarrakhan <alfarrakhan@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mralfarrakhan/svork.git"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "tsdown",
    "prepare": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "unified": "^11.0.5",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "@types/js-yaml": "^4.0.9",
    "dedent": "^1.7.2",
    "js-yaml": "^4.1.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "svelte": "^5.55.9"
  },
  "inlinedDependencies": {
    "@types/unist": "3.0.3",
    "bail": "2.0.2",
    "devlop": "1.1.0",
    "extend": "3.0.2",
    "is-plain-obj": "4.1.0",
    "trough": "2.2.0",
    "unified": "11.0.5",
    "unist-util-stringify-position": "4.0.0",
    "vfile": "6.0.3",
    "vfile-message": "4.0.3"
  }
}
