{
  "name": "@mralfarrakhan/svork",
  "type": "module",
  "version": "0.8.1-alpha",
  "description": "Svelte utilities for writing blog",
  "author": "mralfarrakhan <alfarrakhan@gmail.com",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mralfarrakhan/svork.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --test-timeout=15000",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "bunx tsdown",
    "prepare": "bunx tsdown --dst"
  },
  "devDependencies": {
    "@myriaddreamin/typst-ts-node-compiler": "^0.8.0-rc1",
    "@shikijs/rehype": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.42.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "svelte": "^5.55.10",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "@myriaddreamin/typst-ts-node-compiler": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "@myriaddreamin/typst-ts-node-compiler": {
      "optional": true
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2"
  },
  "inlinedDependencies": {
    "@types/unist": "3.0.3",
    "bail": "2.0.2",
    "devlop": "1.1.0",
    "extend": "3.0.2",
    "is-plain-obj": "4.1.0",
    "trough": "2.2.0",
    "unified": "11.0.5",
    "unist-util-stringify-position": "4.0.0",
    "vfile": "6.0.3",
    "vfile-message": "4.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
